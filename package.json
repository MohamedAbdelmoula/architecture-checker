{
  "name": "technical-analysis-app",
  "version": "1.0.0",
  "description": "Application web implémentant le framework d'analyse technique expert",
  "main": "src/app.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "build": "tsc",
    "test": "jest",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "playwright test",
    "test:coverage": "jest --coverage",
    "test:accessibility": "jest --testPathPattern=accessibility",
    "test:watch": "jest --watch",
    "lint": "eslint src/ --ext .js,.ts",
    "lint:fix": "eslint src/ --ext .js,.ts --fix",
    "format": "prettier --write src/**/*.{js,ts,json}",
    "security:audit": "npm audit --audit-level high",
    "security:scan": "snyk test",
    "docker:build": "docker build -t technical-analysis-app .",
    "docker:run": "docker run -p 3000:3000 technical-analysis-app",
    "docker:dev": "docker-compose up --build",
    "lighthouse": "lighthouse http://localhost:3000 --output-path=./docs/lighthouse-report.html",
    "analyze:bundle": "webpack-bundle-analyzer dist/static/js/*.js",
    "precommit": "npm run lint && npm run test:unit && npm run security:audit"
  },
  "dependencies": {
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "express-slow-down": "^2.0.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "winston-elasticsearch": "^0.17.4",
    "prom-client": "^15.0.0",
    "redis": "^4.6.10",
    "pg": "^8.11.3",
    "joi": "^17.11.0",
    "uuid": "^9.0.1",
    "nodemailer": "^6.9.7",
    "swagger-ui-express": "^5.0.0",
    "swagger-jsdoc": "^6.2.8"
  },
  "devDependencies": {
    "@types/node": "^20.8.9",
    "@types/express": "^4.17.20",
    "@types/jest": "^29.5.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.15",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/uuid": "^9.0.6",
    "@types/nodemailer": "^6.4.13",
    "@types/swagger-ui-express": "^4.1.6",
    "typescript": "^5.2.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "jest-environment-node": "^29.7.0",
    "supertest": "^6.3.3",
    "playwright": "^1.40.0",
    "@playwright/test": "^1.40.0",
    "axe-core": "^4.8.2",
    "@axe-core/playwright": "^4.8.2",
    "lighthouse": "^11.3.0",
    "eslint": "^8.52.0",
    "@typescript-eslint/eslint-plugin": "^6.9.1",
    "@typescript-eslint/parser": "^6.9.1",
    "eslint-plugin-security": "^1.7.1",
    "eslint-plugin-node": "^11.1.0",
    "prettier": "^3.0.3",
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.2",
    "husky": "^8.0.3",
    "lint-staged": "^15.0.2",
    "snyk": "^1.1244.0",
    "webpack-bundle-analyzer": "^4.9.1"
  },
  "lint-staged": {
    "src/**/*.{js,ts}": [
      "eslint --fix",
      "prettier --write",
      "git add"
    ]
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src"],
    "testMatch": ["**/__tests__/**/*.{js,ts}", "**/?(*.)+(spec|test).{js,ts}"],
    "collectCoverageFrom": [
      "src/**/*.{js,ts}",
      "!src/**/*.d.ts",
      "!src/tests/**/*"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov", "html"],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "keywords": [
    "node.js",
    "express",
    "security",
    "monitoring",
    "accessibility",
    "performance",
    "devops",
    "testing",
    "technical-analysis"
  ],
  "author": "Technical Analysis Expert",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/technical-analysis-app.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/technical-analysis-app/issues"
  },
  "homepage": "https://github.com/your-org/technical-analysis-app#readme"
}